{
  "expo": {
    "name": "SK Solutions",
    "slug": "Hourly_Tracker",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "splash": {
        "image": "./assets/images/splash-android.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jai_suresh.k.boltexponativewind"
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f3801e2-2034-430d-9b5d-75789fea340a"
      }
    },
    "owner": "jeyamsuresh1"
  }
}
